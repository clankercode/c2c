#!/usr/bin/env bash
# c2c-cold-boot-hook — PostToolUse hook binary wrapper
#
# Fires once per session: checks for marker, emits cold-boot context, creates marker.
# Installed by `c2c install self` via the PostToolUse hook configuration.

set -euo pipefail

SCRIPT_DIR="$(dirname "$0")"
REPO_ROOT="$(cd "$SCRIPT_DIR" && git rev-parse --show-toplevel 2>/dev/null || echo "$SCRIPT_DIR")"
BIN_PATH="$REPO_ROOT/_build/default/ocaml/tools/c2c_cold_boot_hook.exe"

exec "$BIN_PATH" "$@"
