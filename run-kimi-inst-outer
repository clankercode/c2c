#!/usr/bin/env python3
"""Outer restart loop for run-kimi-inst.

Usage: ./run-kimi-inst-outer <instance-name> [extra kimi args...]

Mirrors run-codex-inst-outer: relaunches the inner script forever,
backs off on fast exits, calls maybe_rearm after each launch to start
the deliver_inbox notify daemon, and exits cleanly on a double SIGINT.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path

MIN_RUN_SECONDS = 10.0
RESTART_PAUSE_SECONDS = 1.5
INITIAL_BACKOFF_SECONDS = 2.0
MAX_BACKOFF_SECONDS = 60.0
DOUBLE_SIGINT_WINDOW_SECONDS = 2.0
HELP_FLAGS = {"-h", "--help"}

HERE = Path(__file__).resolve().parent
INNER = HERE / "run-kimi-inst"
REARM = HERE / "run-kimi-inst-rearm"


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_KIMI_INST_OUTER_DRY_RUN", "").strip().lower() not in {
        "",
        "0",
        "false",
        "no",
        "off",
    }


def inner_command(name: str, extra: list[str]) -> list[str]:
    return [sys.executable, str(INNER), name, *extra]


def rearm_command(name: str) -> list[str]:
    return [sys.executable, str(REARM), name]


def rearm_enabled() -> bool:
    return os.environ.get("RUN_KIMI_INST_REARM", "1").strip().lower() not in {
        "0",
        "false",
        "no",
        "off",
    }


def rearm_log(name: str) -> Path:
    return HERE / "run-kimi-inst.d" / f"{name}.outer.log"


def maybe_rearm(name: str) -> None:
    if not rearm_enabled() or not REARM.exists():
        return
    log_path = rearm_log(name)
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a") as log_fh:
        completed = subprocess.run(
            rearm_command(name), cwd=HERE, check=False,
            stdout=log_fh, stderr=log_fh,
        )
    if completed.returncode != 0:
        print(
            f"[run-kimi-inst-outer] warning: rearm exited code={completed.returncode}"
            f" (see {log_path})",
            file=sys.stderr,
            flush=True,
        )


def main(argv: list[str]) -> int:
    if len(argv) == 2 and argv[1] in HELP_FLAGS:
        print(__doc__.strip())
        return 0
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra kimi args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]

    if not INNER.exists():
        print(f"inner script not found: {INNER}", file=sys.stderr)
        return 2

    command = inner_command(name, extra)
    if dry_run_enabled():
        print(json.dumps({"inner": command, "rearm": rearm_command(name)}, indent=2))
        return 0

    backoff = INITIAL_BACKOFF_SECONDS
    last_sigint = 0.0
    iteration = 0

    while True:
        iteration += 1
        print(f"[run-kimi-inst-outer] iter {iteration}: launching {name}", flush=True)
        started = time.monotonic()
        proc = None
        try:
            proc = subprocess.Popen(command, cwd=HERE, start_new_session=True)
            maybe_rearm(name)
            proc.wait()
            exit_code = proc.returncode
        except KeyboardInterrupt:
            now = time.monotonic()
            # Terminate child if still alive — prevents orphaned kimi processes
            # when the child runs in a new session and didn't receive the SIGINT.
            if proc is not None and proc.poll() is None:
                proc.terminate()
                try:
                    proc.wait(timeout=2.0)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait()
            if now - last_sigint < DOUBLE_SIGINT_WINDOW_SECONDS:
                print("[run-kimi-inst-outer] double SIGINT - exiting.", flush=True)
                return 130
            last_sigint = now
            print(
                "[run-kimi-inst-outer] SIGINT received. Send again within "
                f"{DOUBLE_SIGINT_WINDOW_SECONDS:.1f}s to exit the loop.",
                flush=True,
            )
            exit_code = 130
        except FileNotFoundError as exc:
            print(f"[run-kimi-inst-outer] failed to launch: {exc}", file=sys.stderr)
            return 2

        elapsed = time.monotonic() - started
        print(
            f"[run-kimi-inst-outer] inner exited code={exit_code} after {elapsed:.1f}s",
            flush=True,
        )

        if elapsed < MIN_RUN_SECONDS:
            print(
                f"[run-kimi-inst-outer] fast exit - backing off {backoff:.1f}s",
                flush=True,
            )
            time.sleep(backoff)
            backoff = min(backoff * 2.0, MAX_BACKOFF_SECONDS)
        else:
            backoff = INITIAL_BACKOFF_SECONDS
            time.sleep(RESTART_PAUSE_SECONDS)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except KeyboardInterrupt:
        raise SystemExit(130)
