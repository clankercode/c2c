#!/usr/bin/env python3
"""Outer restart loop for run-kimi-inst.

Usage: ./run-kimi-inst-outer <instance-name> [extra kimi args...]

Mirrors run-codex-inst-outer: relaunches the inner script forever,
backs off on fast exits, calls maybe_rearm after each launch to start
the deliver_inbox notify daemon, and exits cleanly on a double SIGINT.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path

MIN_RUN_SECONDS = 10.0
RESTART_PAUSE_SECONDS = 1.5
INITIAL_BACKOFF_SECONDS = 2.0
MAX_BACKOFF_SECONDS = 60.0
DOUBLE_SIGINT_WINDOW_SECONDS = 2.0
HELP_FLAGS = {"-h", "--help"}
START_NEW_SESSION = False

HERE = Path(__file__).resolve().parent
INNER = HERE / "run-kimi-inst"
REARM = HERE / "run-kimi-inst-rearm"


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_KIMI_INST_OUTER_DRY_RUN", "").strip().lower() not in {
        "",
        "0",
        "false",
        "no",
        "off",
    }


def inner_command(name: str, extra: list[str]) -> list[str]:
    return [sys.executable, str(INNER), name, *extra]


def rearm_command(name: str) -> list[str]:
    return [sys.executable, str(REARM), name]


def rearm_enabled() -> bool:
    return os.environ.get("RUN_KIMI_INST_REARM", "1").strip().lower() not in {
        "0",
        "false",
        "no",
        "off",
    }


def rearm_log(name: str) -> Path:
    return HERE / "run-kimi-inst.d" / f"{name}.outer.log"


def _load_instance_config(name: str) -> dict:
    cfg_path = HERE / "run-kimi-inst.d" / f"{name}.json"
    if not cfg_path.exists():
        return {}
    try:
        return json.loads(cfg_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}


def _load_instance_alias(name: str) -> str | None:
    """Return the c2c alias for a named kimi instance, or None if unresolvable."""
    cfg = _load_instance_config(name)
    return cfg.get("c2c_alias") or cfg.get("c2c_session_id") or None


def _load_instance_session_id(name: str) -> str | None:
    cfg = _load_instance_config(name)
    return (
        cfg.get("c2c_session_id")
        or cfg.get("env", {}).get("C2C_MCP_SESSION_ID")
        or None
    )


def maybe_sanitize_kimi_mcp_config() -> None:
    """Remove stale C2C_MCP_CLIENT_PID from ~/.kimi/mcp.json.

    The managed harness sets C2C_MCP_CLIENT_PID in the child env, so the
    static config value is unnecessary and becomes a footgun when Kimi is
    launched without the harness (e.g., `kimi` directly in a terminal).
    """
    mcp_path = Path.home() / ".kimi" / "mcp.json"
    if not mcp_path.exists():
        return
    try:
        data = json.loads(mcp_path.read_text(encoding="utf-8"))
    except Exception:
        return
    servers = data.get("mcpServers", {})
    c2c = servers.get("c2c")
    if not isinstance(c2c, dict):
        return
    env = c2c.get("env", {})
    if "C2C_MCP_CLIENT_PID" in env:
        del env["C2C_MCP_CLIENT_PID"]
        c2c["env"] = env
        try:
            mcp_path.write_text(json.dumps(data, indent=2, ensure_ascii=False) + "\n", encoding="utf-8")
            print("[run-kimi-inst-outer] sanitized ~/.kimi/mcp.json (removed stale C2C_MCP_CLIENT_PID)", flush=True)
        except Exception as exc:
            print(f"[run-kimi-inst-outer] mcp sanitize error: {exc}", file=sys.stderr, flush=True)


def maybe_refresh_peer(name: str, pid: int) -> None:
    """Update the broker registry to point <name>'s alias at the new child PID.

    This closes the stale-PID window between the old child dying and the new
    child calling auto_register_startup via MCP.  Called immediately after
    subprocess.Popen so the PID is guaranteed alive (execvpe preserves it).
    Silently skips if the registration doesn't exist yet (first launch) or
    if the alias is unresolvable.

    Also passes --session-id to correct session_id drift (see finding
    2026-04-14T03-30-00Z-storm-beacon-session-id-drift-refresh-peer-bug.md).
    """
    alias = _load_instance_alias(name)
    if not alias:
        return
    refresh = HERE / "c2c_refresh_peer.py"
    if not refresh.exists():
        return
    cmd = [sys.executable, str(refresh), alias, "--pid", str(pid)]
    session_id = _load_instance_session_id(name)
    if session_id:
        cmd += ["--session-id", session_id]
    try:
        result = subprocess.run(
            cmd,
            cwd=HERE,
            capture_output=True,
            text=True,
            timeout=5.0,
        )
        if result.returncode != 0:
            # "No registration found" on first launch is expected — not a warning.
            stderr = result.stderr.strip()
            if "No registration found" not in stderr:
                print(
                    f"[run-kimi-inst-outer] refresh-peer warning: {stderr}",
                    file=sys.stderr,
                    flush=True,
                )
    except Exception as exc:
        print(
            f"[run-kimi-inst-outer] refresh-peer error: {exc}",
            file=sys.stderr,
            flush=True,
        )


def _capture_kimi_session(name: str) -> None:
    """Poll ~/.kimi/kimi.json and store the last session id for this cwd.

    Kimi does not expose a CLI to list sessions, but it tracks
    last_session_id per work_dir in kimi.json. We read that file after
    giving the Kimi process time to initialize, then persist the id in
    the instance config so the next restart can use --session <id>.
    """
    cfg_path = HERE / "run-kimi-inst.d" / f"{name}.json"
    if not cfg_path.exists():
        return
    try:
        cfg = json.loads(cfg_path.read_text(encoding="utf-8"))
        cwd = cfg.get("cwd") or str(HERE)
        time.sleep(2.5)
        kimi_json = Path.home() / ".kimi" / "kimi.json"
        if not kimi_json.exists():
            return
        with kimi_json.open("r", encoding="utf-8") as fh:
            data = json.load(fh)
        last_session_id = None
        for wd in data.get("work_dirs", []):
            if wd.get("path") == cwd:
                last_session_id = wd.get("last_session_id")
                break
        if not last_session_id:
            return
        # Basic sanity check: session state file exists and is not archived
        sessions_base = Path.home() / ".kimi" / "sessions"
        state_files = list(sessions_base.rglob(f"{last_session_id}/state.json"))
        if not state_files:
            return
        with state_files[0].open("r", encoding="utf-8") as fh:
            state = json.load(fh)
        if state.get("archived"):
            return
        if cfg.get("kimi_session_id") != last_session_id:
            cfg["kimi_session_id"] = last_session_id
            cfg_path.write_text(json.dumps(cfg, indent=2) + "\n", encoding="utf-8")
            print(
                f"[run-kimi-inst-outer] captured kimi session: {last_session_id}",
                flush=True,
            )
    except Exception as exc:
        print(
            f"[run-kimi-inst-outer] session capture error: {exc}",
            file=sys.stderr,
            flush=True,
        )


def maybe_rearm(name: str) -> None:
    if not rearm_enabled() or not REARM.exists():
        return
    log_path = rearm_log(name)
    log_path.parent.mkdir(parents=True, exist_ok=True)
    with log_path.open("a") as log_fh:
        completed = subprocess.run(
            rearm_command(name), cwd=HERE, check=False,
            stdout=log_fh, stderr=log_fh,
        )
    if completed.returncode != 0:
        print(
            f"[run-kimi-inst-outer] warning: rearm exited code={completed.returncode}"
            f" (see {log_path})",
            file=sys.stderr,
            flush=True,
        )


def main(argv: list[str]) -> int:
    if len(argv) == 2 and argv[1] in HELP_FLAGS:
        print(__doc__.strip())
        return 0
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra kimi args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]

    if not INNER.exists():
        print(f"inner script not found: {INNER}", file=sys.stderr)
        return 2

    command = inner_command(name, extra)
    if dry_run_enabled():
        print(
            json.dumps(
                {
                    "inner": command,
                    "rearm": rearm_command(name),
                    "start_new_session": START_NEW_SESSION,
                },
                indent=2,
            )
        )
        return 0

    backoff = INITIAL_BACKOFF_SECONDS
    last_sigint = 0.0
    iteration = 0

    while True:
        iteration += 1
        import c2c_mcp as _c2c_mcp
        _n = _c2c_mcp.cleanup_stale_tmp_fea_so()
        if _n:
            print(f"[run-kimi-inst-outer] cleaned {_n} stale /tmp/.fea*.so file(s)", flush=True)
        print(f"[run-kimi-inst-outer] iter {iteration}: launching {name}", flush=True)
        started = time.monotonic()
        proc = None
        try:
            proc = subprocess.Popen(command, cwd=HERE, start_new_session=START_NEW_SESSION)
            maybe_refresh_peer(name, proc.pid)
            maybe_sanitize_kimi_mcp_config()
            maybe_rearm(name)
            threading.Thread(target=_capture_kimi_session, args=(name,), daemon=True).start()
            proc.wait()
            exit_code = proc.returncode
        except KeyboardInterrupt:
            now = time.monotonic()
            # Terminate child if still alive — prevents orphaned kimi processes
            # when the child runs in a new session and didn't receive the SIGINT.
            if proc is not None and proc.poll() is None:
                proc.terminate()
                try:
                    proc.wait(timeout=2.0)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait()
            if now - last_sigint < DOUBLE_SIGINT_WINDOW_SECONDS:
                print("[run-kimi-inst-outer] double SIGINT - exiting.", flush=True)
                return 130
            last_sigint = now
            print(
                "[run-kimi-inst-outer] SIGINT received. Send again within "
                f"{DOUBLE_SIGINT_WINDOW_SECONDS:.1f}s to exit the loop.",
                flush=True,
            )
            exit_code = 130
        except FileNotFoundError as exc:
            print(f"[run-kimi-inst-outer] failed to launch: {exc}", file=sys.stderr)
            return 2

        elapsed = time.monotonic() - started
        print(
            f"[run-kimi-inst-outer] inner exited code={exit_code} after {elapsed:.1f}s",
            flush=True,
        )

        if elapsed < MIN_RUN_SECONDS:
            print(
                f"[run-kimi-inst-outer] fast exit - backing off {backoff:.1f}s",
                flush=True,
            )
            time.sleep(backoff)
            backoff = min(backoff * 2.0, MAX_BACKOFF_SECONDS)
        else:
            backoff = INITIAL_BACKOFF_SECONDS
            time.sleep(RESTART_PAUSE_SECONDS)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except KeyboardInterrupt:
        raise SystemExit(130)
