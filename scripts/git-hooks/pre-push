#!/usr/bin/env bash
# pre-push hook — enforces coordinator-only push to origin/master
# Installed to .git/hooks/pre-push by just install-git-hooks.
#
# To bypass (coordinators only): set C2C_COORDINATOR=1 in your environment
# when running `git push`. e.g.:
#   C2C_COORDINATOR=1 git push origin master
#
# Exits 0 (allow) if:
#   - Not pushing to origin/master, OR
#   - C2C_COORDINATOR=1 is set
# Exits 1 (reject) otherwise.

set -euo pipefail

# Git provides:
#   $1 = remote name (e.g. "origin")
#   $2 = remote URL  (e.g. "git@github.com:user/repo.git")
#   stdin = ref lines: "<local_ref> <local_sha> <remote_ref> <remote_sha>"

# Positional args from git
remote_name="${1:-}"
remote_url="${2:-}"

# If no remote (e.g. git push with no remote configured), allow
if [[ -z "$remote_name" ]]; then
  exit 0
fi

# Identify the c2c shared repo by its known remote URLs.
# Patterns covered:
#   - GitHub:        git@github.com:clankercode/c2c.git
#                    https://github.com/clankercode/c2c(.git)?
#   - cachy mirror:  cachy:src/c2c (and any "<host>:src/c2c" SSH alias)
#   - Local clone:   file:///path/to/c2c, /abs/path/to/c2c (rare; matched by trailing /c2c)
# The previous detection ("any origin remote" + "URL contains xertrov") was too broad
# and fired on unrelated repos — see c2c-push-hook-fixes.txt for the full rationale.
is_c2c_repo=false
case "$remote_url" in
  *"clankercode/c2c"|*"clankercode/c2c.git"|*":src/c2c"|*":src/c2c.git"|*"/c2c"|*"/c2c.git")
    is_c2c_repo=true
    ;;
esac

# If not pushing to the c2c repo, allow
if [[ "$is_c2c_repo" != "true" ]]; then
  exit 0
fi

# Coordinator bypass
if [[ "${C2C_COORDINATOR:-}" == "1" ]]; then
  echo "pre-push hook: coordinator bypass — pushing to origin/master" >&2
  exit 0
fi

# Process all ref lines; reject if any pushes to master
reject_master_push() {
  local local_ref="$1"
  local branch="${local_ref#refs/heads/}"

  if [[ "$branch" == "master" ]]; then
    echo "pre-push hook: REJECTED push to origin/master" >&2
    echo "  Only coordinators may push to origin/master." >&2
    echo "  Set C2C_COORDINATOR=1 to bypass (e.g. C2C_COORDINATOR=1 git push)." >&2
    echo "  Or push to a feature branch and open a PR." >&2
    return 1
  fi
  return 0
}

# Read and check each ref line
while read -r local_ref local_sha remote_ref remote_sha; do
  [[ -z "$local_ref" ]] && continue
  [[ "$local_ref" != "refs/heads/"* ]] && continue

  reject_master_push "$local_ref" || exit 1
done

exit 0
