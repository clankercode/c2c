#!/usr/bin/env python3
"""Inner launcher for a named OpenCode instance pinned to repo-local c2c.

Usage: ./run-opencode-inst <instance-name> [extra opencode args...]

Reads config from ./run-opencode-inst.d/<name>.json, sets the c2c env
vars, and execs `opencode run <prompt>` with the named instance's
dedicated OpenCode config file.

Config keys:
  command        opencode binary (default: "opencode")
  cwd            working directory (default: dir containing this script)
  config_path    path to a dedicated <name>.opencode.json config file;
                 exported as OPENCODE_CONFIG so opencode discovers it
                 instead of the repo-level .opencode/opencode.json
  c2c_session_id the MCP session ID (unique per broker registration row)
  c2c_alias      the stable human-readable alias peers use to address
                 this instance; defaults to c2c_session_id if absent.
                 Use this when alias != session_id (e.g. alias=opencode-local,
                 session_id=ses_abc123).
  prompt         opencode run prompt text; also exported as
                 OPENCODE_MCP_PROMPT for MCP/plugin startup context
  flags          extra flags before (list of strings)
  session        opencode session ID to resume (optional)

Set RUN_OPENCODE_INST_DRY_RUN=1 to print the resolved launch command,
cwd, and env keys as JSON instead of execing.
"""
from __future__ import annotations

import json
import os
import shlex
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
CONFIG_DIR = HERE / "run-opencode-inst.d"
FALSE_STRINGS = {"", "0", "false", "no", "off"}


def config_dir() -> Path:
    override = os.environ.get("RUN_OPENCODE_INST_CONFIG_DIR", "").strip()
    return Path(override) if override else CONFIG_DIR


def config_path(name: str) -> Path:
    return config_dir() / f"{name}.json"


def pid_path(name: str) -> Path:
    return config_dir() / f"{name}.pid"


def restart_marker_path(name: str) -> Path:
    return config_dir() / f"{name}.restart.json"


def load_config(name: str) -> dict:
    path = config_path(name)
    if not path.exists():
        raise SystemExit(f"[run-opencode-inst] config not found: {path}")
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"[run-opencode-inst] invalid JSON in {path}: {exc}")
    if not isinstance(data, dict):
        raise SystemExit(f"[run-opencode-inst] config root must be an object: {path}")
    return data


def coerce_string(value, field: str, *, required: bool = False) -> str:
    if value is None:
        if required:
            raise SystemExit(f"[run-opencode-inst] {field} is required")
        return ""
    if not isinstance(value, str):
        raise SystemExit(f"[run-opencode-inst] {field} must be a string")
    if required and not value:
        raise SystemExit(f"[run-opencode-inst] {field} must not be empty")
    return value


def coerce_string_list(value, field: str) -> list[str]:
    if value is None:
        return []
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise SystemExit(f"[run-opencode-inst] {field} must be list of strings")
    return list(value)


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_OPENCODE_INST_DRY_RUN", "").strip().lower() not in FALSE_STRINGS


def silent_enabled() -> bool:
    return os.environ.get("RUN_OPENCODE_INST_SILENT", "").strip().lower() not in FALSE_STRINGS


def build_resume_args(config: dict) -> list[str]:
    continue_last = config.get("continue_last") is True
    session = coerce_string(config.get("session"), "session")
    if continue_last and session:
        raise SystemExit(
            "[run-opencode-inst] configure either continue_last or session, not both"
        )
    if continue_last:
        return ["--continue"]
    if session:
        return ["--session", session]
    return []


def _ensure_opencode_plugin(config_path: Path, cwd_path: Path) -> None:
    """Copy c2c plugin into the config directory if using a custom config path.

    OpenCode only discovers plugins relative to its config file directory.
    When a managed instance uses a dedicated config file outside the repo
    .opencode/ directory, we must sync the plugin there so it loads.

    Also ensures node_modules is accessible by symlinking from config_dir to
    the installed .opencode/node_modules — otherwise Bun can't resolve
    @opencode-ai/plugin when loading the plugin from the config dir.
    """
    repo_opencode = cwd_path / ".opencode"
    plugin_src = repo_opencode / "plugins" / "c2c.ts"
    if not plugin_src.exists():
        return
    config_dir = config_path.parent
    if config_dir == repo_opencode:
        return
    plugin_dest = config_dir / "plugins" / "c2c.ts"
    plugin_dest.parent.mkdir(parents=True, exist_ok=True)
    import shutil
    shutil.copy2(str(plugin_src), str(plugin_dest))
    pkg_src = repo_opencode / "package.json"
    pkg_dest = config_dir / "package.json"
    if pkg_src.exists():
        if pkg_dest.exists():
            try:
                existing = json.loads(pkg_dest.read_text(encoding="utf-8"))
            except (json.JSONDecodeError, OSError):
                existing = {}
            src_pkg = json.loads(pkg_src.read_text(encoding="utf-8"))
            deps = existing.setdefault("dependencies", {})
            for k, v in src_pkg.get("dependencies", {}).items():
                if k not in deps:
                    deps[k] = v
            pkg_dest.write_text(json.dumps(existing, indent=2) + "\n", encoding="utf-8")
        else:
            shutil.copy2(str(pkg_src), str(pkg_dest))
    # Symlink node_modules so Bun can resolve @opencode-ai/plugin when running
    # the plugin from the dedicated config directory.
    nm_src = repo_opencode / "node_modules"
    nm_dest = config_dir / "node_modules"
    if nm_src.exists() and not nm_dest.exists():
        os.symlink(str(nm_src), str(nm_dest))


def _write_plugin_sidecar(
    cwd_path: Path, c2c_session_id: str, c2c_alias: str, broker_root: Path
) -> None:
    sidecar = cwd_path / ".opencode" / "c2c-plugin.json"
    sidecar.parent.mkdir(parents=True, exist_ok=True)
    sidecar.write_text(
        json.dumps(
            {
                "session_id": c2c_session_id,
                "alias": c2c_alias,
                "broker_root": str(broker_root),
            },
            indent=2,
        )
        + "\n",
        encoding="utf-8",
    )


def build_launch(name: str, config: dict, extra: list[str]) -> tuple[list[str], Path, dict[str, str]]:
    command = coerce_string(config.get("command", "opencode"), "command", required=True)
    cwd = coerce_string(config.get("cwd") or str(HERE), "cwd", required=True)
    cwd_path = Path(cwd).expanduser()
    if not cwd_path.exists():
        raise SystemExit(f"[run-opencode-inst] cwd does not exist: {cwd_path}")
    config_path_value = coerce_string(
        config.get("config_path") or str(cwd_path / ".opencode" / "opencode.json"),
        "config_path",
        required=True,
    )
    config_path = Path(config_path_value).expanduser()
    _ensure_opencode_plugin(config_path, cwd_path)
    c2c_session_id = coerce_string(config.get("c2c_session_id"), "c2c_session_id", required=True)
    # c2c_alias is the stable human-readable name registered in the broker.
    # When it differs from c2c_session_id (e.g. alias="opencode-local",
    # session_id="ses_abc123"), AUTO_REGISTER_ALIAS must use the alias so that
    # peers can address messages to the intended name regardless of the MCP
    # process's internal session ID.
    c2c_alias = coerce_string(config.get("c2c_alias") or c2c_session_id, "c2c_alias", required=False)
    prompt = coerce_string(config.get("prompt"), "prompt", required=True)
    flags = coerce_string_list(config.get("flags"), "flags")
    resume_args = build_resume_args(config)

    launch = [command, *flags, *resume_args, *extra, "--prompt", prompt]

    env = os.environ.copy()
    env["RUN_OPENCODE_INST_NAME"] = name
    env["RUN_OPENCODE_INST_C2C_SESSION_ID"] = c2c_session_id
    env["RUN_OPENCODE_INST_CONFIG_PATH"] = config_path_value
    env["OPENCODE_MCP_PROMPT"] = prompt
    # OPENCODE_CONFIG: the path opencode reads to discover its config file.
    # OPENCODE_CONFIG_CONTENT: the file content for debugging / dry-run inspection.
    env["OPENCODE_CONFIG"] = config_path_value
    env["OPENCODE_CONFIG_CONTENT"] = Path(config_path_value).read_text(encoding="utf-8")
    restart_marker = restart_marker_path(name)
    env["RUN_OPENCODE_INST_RESTART_MARKER"] = str(restart_marker)
    env["C2C_MCP_SESSION_ID"] = c2c_session_id
    # This process execs into the durable OpenCode client, so its pid is the
    # right liveness target for MCP auto-registration children to inherit.
    env["C2C_MCP_CLIENT_PID"] = str(os.getpid())
    env["C2C_MCP_AUTO_REGISTER_ALIAS"] = c2c_alias
    broker_root = cwd_path / ".git" / "c2c" / "mcp"
    env["C2C_MCP_BROKER_ROOT"] = str(broker_root)
    env["C2C_MCP_AUTO_DRAIN_CHANNEL"] = "0"
    _write_plugin_sidecar(cwd_path, c2c_session_id, c2c_alias, broker_root)
    return launch, cwd_path, env


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra opencode args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]
    config = load_config(name)
    launch, cwd_path, env = build_launch(name, config, extra)
    pre_exec = coerce_string_list(config.get("pre_exec"), "pre_exec")

    if dry_run_enabled():
        print(
            json.dumps(
                {
                    "launch": launch,
                    "cwd": str(cwd_path),
                    "pid_file": str(pid_path(name)),
                    "pre_exec": pre_exec,
                    "env": {
                        "RUN_OPENCODE_INST_NAME": env["RUN_OPENCODE_INST_NAME"],
                        "RUN_OPENCODE_INST_C2C_SESSION_ID": env["RUN_OPENCODE_INST_C2C_SESSION_ID"],
                        "RUN_OPENCODE_INST_CONFIG_PATH": env["RUN_OPENCODE_INST_CONFIG_PATH"],
                        "OPENCODE_MCP_PROMPT": env["OPENCODE_MCP_PROMPT"],
                        "OPENCODE_CONFIG": env["OPENCODE_CONFIG"],
                        "OPENCODE_CONFIG_CONTENT": env["OPENCODE_CONFIG_CONTENT"],
                        "RUN_OPENCODE_INST_RESTART_MARKER": env["RUN_OPENCODE_INST_RESTART_MARKER"],
                        "C2C_MCP_SESSION_ID": env["C2C_MCP_SESSION_ID"],
                        "C2C_MCP_CLIENT_PID": env["C2C_MCP_CLIENT_PID"],
                        "C2C_MCP_AUTO_REGISTER_ALIAS": env["C2C_MCP_AUTO_REGISTER_ALIAS"],
                        "C2C_MCP_BROKER_ROOT": env["C2C_MCP_BROKER_ROOT"],
                        "C2C_MCP_AUTO_DRAIN_CHANNEL": env["C2C_MCP_AUTO_DRAIN_CHANNEL"],
                    },
                },
                indent=2,
            )
        )
        return 0

    pid_file = pid_path(name)
    pid_file.parent.mkdir(parents=True, exist_ok=True)
    pid_file.write_text(f"{os.getpid()}\n", encoding="utf-8")
    if pre_exec:
        if not silent_enabled():
            print(f"[run-opencode-inst] pre_exec: {shlex.join(pre_exec)}", file=sys.stderr)
        subprocess.run(pre_exec, cwd=str(cwd_path), env=env, check=False)

    if not silent_enabled():
        print(f"[run-opencode-inst] exec {shlex.join(launch)} (cwd={cwd_path})", file=sys.stderr)
    os.chdir(str(cwd_path))
    try:
        os.execvpe(launch[0], launch, env)
    except FileNotFoundError as exc:
        raise SystemExit(f"[run-opencode-inst] command not found: {launch[0]} ({exc})")


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
