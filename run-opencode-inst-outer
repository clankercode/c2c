#!/usr/bin/env python3
"""Outer restart loop for run-opencode-inst.

Usage: ./run-opencode-inst-outer <instance-name> [extra opencode args...]

Mirrors run-codex-inst-outer: relaunches the inner script forever,
backs off on fast exits, and exits cleanly on a double SIGINT.
"""
from __future__ import annotations

import json
import os
import subprocess
import sys
import time
from pathlib import Path

MIN_RUN_SECONDS = 10.0
RESTART_PAUSE_SECONDS = 1.5
INITIAL_BACKOFF_SECONDS = 2.0
MAX_BACKOFF_SECONDS = 60.0
DOUBLE_SIGINT_WINDOW_SECONDS = 2.0

HERE = Path(__file__).resolve().parent
INNER = HERE / "run-opencode-inst"
REARM = HERE / "run-opencode-inst-rearm"


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_OPENCODE_INST_OUTER_DRY_RUN", "").strip().lower() not in {
        "",
        "0",
        "false",
        "no",
        "off",
    }


def inner_command(name: str, extra: list[str]) -> list[str]:
    return [sys.executable, str(INNER), name, *extra]


def rearm_command(name: str) -> list[str]:
    return [sys.executable, str(REARM), name]


def rearm_enabled() -> bool:
    return os.environ.get("RUN_OPENCODE_INST_REARM", "1").strip().lower() not in {
        "0",
        "false",
        "no",
        "off",
    }


def maybe_rearm(name: str) -> None:
    if not rearm_enabled() or not REARM.exists():
        return
    completed = subprocess.run(rearm_command(name), cwd=HERE, check=False)
    if completed.returncode != 0:
        print(
            f"[run-opencode-inst-outer] warning: rearm exited code={completed.returncode}",
            flush=True,
        )


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra opencode args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]

    if not INNER.exists():
        print(f"inner script not found: {INNER}", file=sys.stderr)
        return 2

    command = inner_command(name, extra)
    if dry_run_enabled():
        print(json.dumps({"inner": command, "rearm": rearm_command(name)}, indent=2))
        return 0

    backoff = INITIAL_BACKOFF_SECONDS
    last_sigint = 0.0
    iteration = 0

    while True:
        iteration += 1
        print(f"[run-opencode-inst-outer] iter {iteration}: launching {name}", flush=True)
        started = time.monotonic()
        proc = None
        try:
            proc = subprocess.Popen(command, cwd=HERE, start_new_session=True)
            time.sleep(0.5)
            maybe_rearm(name)
            exit_code = proc.wait()
        except KeyboardInterrupt:
            now = time.monotonic()
            if now - last_sigint < DOUBLE_SIGINT_WINDOW_SECONDS:
                if proc is not None and proc.poll() is None:
                    proc.terminate()
                print("[run-opencode-inst-outer] double SIGINT - exiting.", flush=True)
                return 130
            last_sigint = now
            print(
                "[run-opencode-inst-outer] SIGINT received. Send again within "
                f"{DOUBLE_SIGINT_WINDOW_SECONDS:.1f}s to exit the loop.",
                flush=True,
            )
            exit_code = 130
        except FileNotFoundError as exc:
            print(f"[run-opencode-inst-outer] failed to launch: {exc}", file=sys.stderr)
            return 2

        elapsed = time.monotonic() - started
        print(
            f"[run-opencode-inst-outer] inner exited code={exit_code} after {elapsed:.1f}s",
            flush=True,
        )

        if elapsed < MIN_RUN_SECONDS:
            print(
                f"[run-opencode-inst-outer] fast exit - backing off {backoff:.1f}s",
                flush=True,
            )
            time.sleep(backoff)
            backoff = min(backoff * 2.0, MAX_BACKOFF_SECONDS)
        else:
            backoff = INITIAL_BACKOFF_SECONDS
            time.sleep(RESTART_PAUSE_SECONDS)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except KeyboardInterrupt:
        raise SystemExit(130)
