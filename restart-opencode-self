#!/usr/bin/env python3
"""
Self-restart helper for a run-opencode-inst managed session.

Usage: ./restart-opencode-self [instance-name] [--signal SIGNAME] [--reason TEXT]

Reads the pid written by `run-opencode-inst` for the given instance
(default: $RUN_OPENCODE_INST_NAME) and sends it a signal (default: SIGTERM).
When the managed OpenCode process exits, `run-opencode-inst-outer` relaunches
it from the same config. The relaunched process uses the config's
`continue_last` / `session` selector to resume the intended OpenCode session.
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import sys
import time
from pathlib import Path

HERE = Path(__file__).resolve().parent
DEFAULT_CONFIG_DIR = HERE / "run-opencode-inst.d"
FALSE_STRINGS = {"", "0", "false", "no", "off"}


def config_dir() -> Path:
    override = os.environ.get("RUN_OPENCODE_INST_CONFIG_DIR", "").strip()
    return Path(override) if override else DEFAULT_CONFIG_DIR


def pid_path(name: str) -> Path:
    return config_dir() / f"{name}.pid"


def restart_marker_path(name: str) -> Path:
    return config_dir() / f"{name}.restart.json"


def proc_comm(pid: int) -> str | None:
    try:
        return Path(f"/proc/{pid}/comm").read_text(encoding="utf-8").strip()
    except (FileNotFoundError, OSError):
        return None


def proc_group_id(pid: int) -> int | None:
    try:
        return os.getpgid(pid)
    except ProcessLookupError:
        return None


def collect_descendants(pid: int) -> list[int]:
    """Return all descendant pids of pid using /proc/<pid>/task/*/children."""
    result: list[int] = []
    try:
        task_dir = Path(f"/proc/{pid}/task")
        for tid_dir in task_dir.iterdir():
            children_file = tid_dir / "children"
            try:
                child_pids = [
                    int(x)
                    for x in children_file.read_text(encoding="utf-8").split()
                ]
                for child in child_pids:
                    result.append(child)
                    result.extend(collect_descendants(child))
            except (FileNotFoundError, ValueError, OSError):
                pass
    except (FileNotFoundError, OSError):
        pass
    return result


def kill_survivors(root_pid: int, sig: signal.Signals) -> list[int]:
    """Kill all surviving descendants of root_pid. Returns list of pids signaled."""
    killed: list[int] = []
    for pid in collect_descendants(root_pid):
        if pid <= 1 or pid == os.getpid():
            continue
        try:
            os.kill(pid, sig.value)
            killed.append(pid)
        except ProcessLookupError:
            pass  # already gone
        except PermissionError:
            pass  # not ours to kill
    return killed


def kill_pid_list(pids: list[int], sig: signal.Signals) -> list[int]:
    """Kill the provided pid list, ignoring already-dead processes."""
    killed: list[int] = []
    for pid in pids:
        if pid <= 1 or pid == os.getpid():
            continue
        try:
            os.kill(pid, sig.value)
            killed.append(pid)
        except ProcessLookupError:
            pass
        except PermissionError:
            pass
    return killed


def dry_run_enabled() -> bool:
    # Accept both the canonical name and the shorter variant to avoid footguns
    # where agents set the wrong env var name and accidentally signal the process.
    for var in ("RUN_OPENCODE_RESTART_SELF_DRY_RUN", "RUN_OPENCODE_INST_RESTART_SELF_DRY_RUN"):
        val = os.environ.get(var, "").strip().lower()
        if val and val not in FALSE_STRINGS:
            return True
    return False


def expected_comm_values(value: str) -> list[str]:
    return [item.strip() for item in value.split(",") if item.strip()]


def comm_matches(comm: str, expected: list[str]) -> bool:
    return any(needle in comm for needle in expected)


def parse_signal(value: str) -> signal.Signals:
    signal_name = value if value.startswith("SIG") else f"SIG{value}"
    try:
        return signal.Signals[signal_name]
    except KeyError:
        raise SystemExit(f"[restart-opencode-self] unknown signal: {value}")


def write_restart_marker(
    *,
    name: str,
    pid: int,
    pid_file: Path,
    sig: signal.Signals,
    comm: str,
    reason: str,
    dry_run: bool,
    process_group: int | None,
) -> Path | None:
    if not reason:
        return None
    marker_path = restart_marker_path(name)
    marker_path.parent.mkdir(parents=True, exist_ok=True)
    marker_path.write_text(
        json.dumps(
            {
                "name": name,
                "pid": pid,
                "pid_file": str(pid_file),
                "signal": sig.name,
                "comm": comm,
                "process_group": process_group,
                "reason": reason,
                "dry_run": dry_run,
                "created_at": time.strftime("%Y-%m-%dT%H:%M:%SZ", time.gmtime()),
            },
            indent=2,
        )
        + "\n",
        encoding="utf-8",
    )
    return marker_path


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="Self-restart a run-opencode-inst session."
    )
    parser.add_argument(
        "name",
        nargs="?",
        default=os.environ.get("RUN_OPENCODE_INST_NAME"),
        help="instance name (default: $RUN_OPENCODE_INST_NAME)",
    )
    parser.add_argument(
        "--signal",
        default="SIGTERM",
        help="signal to send (default: SIGTERM); e.g. SIGINT, SIGHUP, TERM",
    )
    parser.add_argument(
        "--expect-comm",
        default="opencode,node,npm,MainThread",
        help=(
            "comma-separated /proc/<pid>/comm substring allowlist "
            "(default: opencode,node,npm,MainThread). Use '' to skip the check."
        ),
    )
    parser.add_argument(
        "--reason",
        default="",
        help="optional restart reason to persist for the resumed OpenCode turn",
    )
    args = parser.parse_args(argv[1:])

    if not args.name:
        print(
            "[restart-opencode-self] no instance name; pass as arg or set $RUN_OPENCODE_INST_NAME",
            file=sys.stderr,
        )
        return 2

    pid_file = pid_path(args.name)
    if not pid_file.exists():
        print(f"[restart-opencode-self] pid file not found: {pid_file}", file=sys.stderr)
        return 2

    try:
        pid = int(pid_file.read_text(encoding="utf-8").strip())
    except ValueError:
        print(
            f"[restart-opencode-self] pid file is not an integer: {pid_file}",
            file=sys.stderr,
        )
        return 2

    if pid <= 1:
        print(f"[restart-opencode-self] refusing to signal pid {pid}", file=sys.stderr)
        return 2
    if pid == os.getpid():
        print("[restart-opencode-self] refusing to signal our own pid", file=sys.stderr)
        return 2

    comm = proc_comm(pid)
    if comm is None:
        print(
            f"[restart-opencode-self] pid {pid} has no /proc entry (already exited?)",
            file=sys.stderr,
        )
        return 3

    expected = expected_comm_values(args.expect_comm)
    if expected and not comm_matches(comm, expected):
        print(
            f"[restart-opencode-self] pid {pid} /proc comm is {comm!r}, expected one of {expected!r} - refusing to signal",
            file=sys.stderr,
        )
        return 4

    sig = parse_signal(args.signal)
    dry_run = dry_run_enabled()
    process_group = proc_group_id(pid)
    descendant_snapshot = sorted(set(collect_descendants(pid)))

    if dry_run:
        print(
            json.dumps(
                {
                    "name": args.name,
                    "pid": pid,
                    "pid_file": str(pid_file),
                    "signal": sig.name,
                    "comm": comm,
                    "process_group": process_group,
                    "reason": args.reason,
                    "reason_file": str(restart_marker_path(args.name)) if args.reason else None,
                    "dry_run": True,
                },
                indent=2,
            )
        )
        return 0

    marker_path = write_restart_marker(
        name=args.name,
        pid=pid,
        pid_file=pid_file,
        sig=sig,
        comm=comm,
        reason=args.reason,
        dry_run=False,
        process_group=process_group,
    )

    target_desc = f"process-group {process_group}" if process_group and process_group > 1 else f"pid {pid}"
    print(
        f"[restart-opencode-self] sending {sig.name} to {target_desc} (pid={pid}, comm={comm!r}) - outer loop will relaunch",
        file=sys.stderr,
        flush=True,
    )
    if marker_path is not None:
        print(
            f"[restart-opencode-self] wrote restart marker: {marker_path}",
            file=sys.stderr,
            flush=True,
        )
    # Detach from the target process group before signaling so that a killpg
    # call does not also kill this process. restart-opencode-self may be a
    # grandchild of opencode and would otherwise receive SIGTERM itself.
    try:
        os.setpgrp()
    except OSError:
        pass  # fine if we're already a group leader

    try:
        if process_group and process_group > 1:
            os.killpg(process_group, sig.value)
        else:
            os.kill(pid, sig.value)
    except ProcessLookupError:
        print(f"[restart-opencode-self] target vanished before signal (pid={pid}, pgid={process_group})", file=sys.stderr)
        return 3
    except PermissionError:
        print(
            f"[restart-opencode-self] permission denied signaling target (pid={pid}, pgid={process_group})",
            file=sys.stderr,
        )
        return 4

    # After the initial signal, wait briefly then kill any surviving descendants
    # that created their own process groups (OpenCode workers can do this).
    # This prevents orphaned workers from sharing the session with the relaunched instance.
    survivor_kill_delay = float(os.environ.get("RUN_OPENCODE_RESTART_SURVIVOR_KILL_DELAY", "1.5"))
    if survivor_kill_delay > 0:
        time.sleep(survivor_kill_delay)
    remaining_descendants = collect_descendants(pid)
    survivors = kill_pid_list(
        sorted(set(descendant_snapshot + remaining_descendants)), signal.SIGKILL
    )
    if survivors:
        print(
            f"[restart-opencode-self] sent SIGKILL to {len(survivors)} surviving descendant(s): {survivors}",
            file=sys.stderr,
            flush=True,
        )
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
