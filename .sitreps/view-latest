#!/usr/bin/env python3
"""view-latest — display the most recent sitrep with colorized markdown via rich."""

from __future__ import annotations

import argparse
import re
import subprocess
import sys
from datetime import datetime
from pathlib import Path

from rich.console import Console
from rich.markdown import Markdown
from rich.panel import Panel

REPO_ROOT = Path(__file__).resolve().parent.parent
SITREPS_DIR = REPO_ROOT / ".sitreps"


def print_via_pager(content: str) -> None:
    """Print content through less -R for less-like scrolling."""
    proc = subprocess.Popen(
        ["less", "-R"],
        stdin=subprocess.PIPE,
        stdout=sys.stdout,
        stderr=sys.stderr,
    )
    try:
        proc.communicate(input=content.encode("utf-8"))
    except KeyboardInterrupt:
        proc.terminate()
        proc.wait()


def find_latest_sitrep() -> Path | None:
    """Find the most recent sitrep file by scanning date dirs."""
    if not SITREPS_DIR.exists():
        return None

    latest: Path | None = None
    latest_dt: datetime | None = None

    for year_dir in sorted(SITREPS_DIR.iterdir(), reverse=True):
        if not year_dir.is_dir():
            continue
        try:
            year = int(year_dir.name)
        except ValueError:
            continue
        for month_dir in sorted(year_dir.iterdir(), reverse=True):
            if not month_dir.is_dir():
                continue
            try:
                month = int(month_dir.name)
            except ValueError:
                continue
            for day_dir in sorted(month_dir.iterdir(), reverse=True):
                if not day_dir.is_dir():
                    continue
                try:
                    day = int(day_dir.name)
                except ValueError:
                    continue
                for sitrep_file in sorted(day_dir.iterdir(), reverse=True):
                    if not sitrep_file.is_file() or not re.match(r"^\d\d\.md$", sitrep_file.name):
                        continue
                    try:
                        hour = int(sitrep_file.stem)
                    except ValueError:
                        continue
                    dt_candidate = datetime(year, month, day, hour)
                    if latest_dt is None or dt_candidate > latest_dt:
                        latest_dt = dt_candidate
                        latest = sitrep_file
    return latest


def build_sitrep_output(sitrep: Path, ts: str) -> str:
    """Build the full rich-rendered sitrep as an ANSI string."""
    sitrep = sitrep.resolve()
    content = sitrep.read_text()
    console = Console(force_terminal=True, file=sys.stdout)
    panel = Panel(
        f"[bold cyan]Sitrep:[/bold cyan] {ts}\n[dim]Path:[/dim] {sitrep.relative_to(REPO_ROOT)}",
        title="c2c sitrep",
        border_style="cyan",
    )
    with console.capture() as capture:
        console.print(panel)
        console.print()
        md = Markdown(content, code_theme="monokai")
        console.print(md)
    return capture.get()


def main() -> int:
    parser = argparse.ArgumentParser(description="Display the latest c2c sitrep.")
    parser.add_argument(
        "--print",
        action="store_true",
        help="Print all output at once instead of using a pager",
    )
    parser.add_argument(
        "--path",
        metavar="FILE",
        help="Display a specific sitrep file instead of the latest",
    )
    args = parser.parse_args()

    if args.path:
        sitrep = Path(args.path)
        if not sitrep.exists():
            print(f"error: {sitrep} not found", file=sys.stderr)
            return 1
        ts = sitrep.stem
    else:
        sitrep = find_latest_sitrep()
        if sitrep is None:
            print("No sitreps found.", file=sys.stderr)
            return 1
        year = sitrep.parent.parent.parent.name
        month = sitrep.parent.parent.name
        day = sitrep.parent.name
        ts = f"{year}-{month}-{day} {sitrep.stem}:00 UTC"

    output = build_sitrep_output(sitrep, ts)

    if args.print:
        sys.stdout.write(output)
        sys.stdout.flush()
    else:
        print_via_pager(output)

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
