#!/usr/bin/env python3
"""view-latest — display the most recent sitrep with colorized markdown via rich."""

from __future__ import annotations

import re
import sys
from datetime import datetime
from pathlib import Path

from rich.console import Console
from rich.markdown import Markdown
from rich.panel import Panel

REPO_ROOT = Path(__file__).resolve().parent.parent
SITREPS_DIR = REPO_ROOT / ".sitreps"

console = Console()


def find_latest_sitrep() -> Path | None:
    """Find the most recent sitrep file by scanning date dirs."""
    if not SITREPS_DIR.exists():
        return None

    latest: Path | None = None
    latest_dt: datetime | None = None

    for year_dir in sorted(SITREPS_DIR.iterdir(), reverse=True):
        if not year_dir.is_dir():
            continue
        try:
            year = int(year_dir.name)
        except ValueError:
            continue
        for month_dir in sorted(year_dir.iterdir(), reverse=True):
            if not month_dir.is_dir():
                continue
            try:
                month = int(month_dir.name)
            except ValueError:
                continue
            for day_dir in sorted(month_dir.iterdir(), reverse=True):
                if not day_dir.is_dir():
                    continue
                try:
                    day = int(day_dir.name)
                except ValueError:
                    continue
                for sitrep_file in sorted(day_dir.iterdir(), reverse=True):
                    if not sitrep_file.is_file() or not re.match(r"^\d\d\.md$", sitrep_file.name):
                        continue
                    try:
                        hour = int(sitrep_file.stem)
                    except ValueError:
                        continue
                    dt_candidate = datetime(year, month, day, hour)
                    if latest_dt is None or dt_candidate > latest_dt:
                        latest_dt = dt_candidate
                        latest = sitrep_file
    return latest


def render_sitrep(content: str) -> None:
    """Render sitrep markdown with rich markdown renderer."""
    md = Markdown(content, code_theme="monokai")
    console.print(md)


def main() -> int:
    sitrep = find_latest_sitrep()
    if sitrep is None:
        console.print("[red]No sitreps found.[/red]")
        return 1

    content = sitrep.read_text()

    year = sitrep.parent.parent.parent.name
    month = sitrep.parent.parent.name
    day = sitrep.parent.name
    hour_part = sitrep.stem
    ts = f"{year}-{month}-{day} {hour_part}:00 UTC"

    panel = Panel(
        f"[bold cyan]Sitrep:[/bold cyan] {ts}\n[dim]Path:[/dim] {sitrep.relative_to(REPO_ROOT)}",
        title="c2c sitrep",
        border_style="cyan",
    )
    console.print(panel)
    console.print()
    render_sitrep(content)
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
