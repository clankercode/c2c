#!/usr/bin/env python3
"""
Outer loop for run-claude-inst.

Usage: ./run-claude-inst-outer <instance-name>

Runs ./run-claude-inst <instance-name> in a loop so the model (or a human)
can edit the inner script or its config between iterations to change its
own launch flags. Python is used rather than bash so that in-flight edits
to the inner script are safe: subprocess.run loads the script fresh each
iteration.

Loop semantics:
- Wait for the inner to exit.
- If it exited within < MIN_RUN_SECONDS, count it as a crash and apply
  exponential backoff up to MAX_BACKOFF_SECONDS to avoid tight crash loops.
- Otherwise reset backoff and re-launch after RESTART_PAUSE_SECONDS so
  the user has a chance to Ctrl-C the outer.
- SIGINT in the outer (double Ctrl-C in quick succession) exits the loop.
"""
from __future__ import annotations

import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

MIN_RUN_SECONDS = 10.0
RESTART_PAUSE_SECONDS = 1.5
INITIAL_BACKOFF_SECONDS = 2.0
MAX_BACKOFF_SECONDS = 60.0
DOUBLE_SIGINT_WINDOW_SECONDS = 2.0

HERE = Path(__file__).resolve().parent
INNER = HERE / "run-claude-inst"


def _load_instance_config(name: str) -> dict:
    cfg_path = HERE / "run-claude-inst.d" / f"{name}.json"
    if not cfg_path.exists():
        return {}
    try:
        return json.loads(cfg_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}


def _load_instance_alias(name: str) -> str | None:
    cfg = _load_instance_config(name)
    return cfg.get("c2c_alias") or cfg.get("c2c_session_id") or None


def _load_instance_session_id(name: str) -> str | None:
    """Extract the expected C2C session_id from the instance config.

    For Claude instances, the session_id lives in env.C2C_MCP_SESSION_ID
    (a UUID set per --resume slot). For other clients it is top-level
    c2c_session_id. Returns None if not found.
    """
    cfg = _load_instance_config(name)
    # Top-level first (Kimi, Codex, OpenCode, Crush)
    sid = cfg.get("c2c_session_id")
    if sid:
        return sid
    # Claude instances store it in the env dict
    return cfg.get("env", {}).get("C2C_MCP_SESSION_ID") or None


def maybe_refresh_peer(name: str, pid: int) -> None:
    """Update the broker registry to point <name>'s alias at the new child PID.

    Also passes --session-id if the config has one, so that a stale entry with
    the wrong session_id (e.g. from a previous OpenCode run in the same project)
    is corrected atomically. Without this, Guard 2 in auto_register_startup can
    block the MCP server from re-registering with the correct session_id.
    """
    alias = _load_instance_alias(name)
    if not alias:
        return
    refresh = HERE / "c2c_refresh_peer.py"
    if not refresh.exists():
        return
    cmd = [sys.executable, str(refresh), alias, "--pid", str(pid)]
    session_id = _load_instance_session_id(name)
    if session_id:
        cmd += ["--session-id", session_id]
    try:
        result = subprocess.run(
            cmd,
            cwd=HERE,
            capture_output=True,
            text=True,
            timeout=5.0,
        )
        if result.returncode != 0:
            stderr = result.stderr.strip()
            if "No registration found" not in stderr:
                print(
                    f"[run-claude-inst-outer] refresh-peer warning: {stderr}",
                    file=sys.stderr,
                    flush=True,
                )
    except Exception as exc:
        print(
            f"[run-claude-inst-outer] refresh-peer error: {exc}",
            file=sys.stderr,
            flush=True,
        )


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name>", file=sys.stderr)
        return 2
    name = argv[1]
    extra = argv[2:]

    if not INNER.exists():
        print(f"inner script not found: {INNER}", file=sys.stderr)
        return 2

    backoff = INITIAL_BACKOFF_SECONDS
    last_sigint = 0.0
    iteration = 0

    while True:
        iteration += 1
        print(f"[run-claude-inst-outer] iter {iteration}: launching {name}", flush=True)
        started = time.monotonic()
        proc = None
        try:
            proc = subprocess.Popen([sys.executable, str(INNER), name, *extra], cwd=HERE)
            maybe_refresh_peer(name, proc.pid)
            exit_code = proc.wait()
        except KeyboardInterrupt:
            if proc is not None and proc.poll() is None:
                proc.terminate()
                try:
                    proc.wait(timeout=2.0)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait()
            now = time.monotonic()
            if now - last_sigint < DOUBLE_SIGINT_WINDOW_SECONDS:
                print("[run-claude-inst-outer] double SIGINT — exiting.", flush=True)
                return 130
            last_sigint = now
            print(
                "[run-claude-inst-outer] SIGINT received. Send again within "
                f"{DOUBLE_SIGINT_WINDOW_SECONDS:.1f}s to exit the loop.",
                flush=True,
            )
            exit_code = 130
        except FileNotFoundError as exc:
            print(f"[run-claude-inst-outer] failed to launch: {exc}", file=sys.stderr, flush=True)
            return 2

        elapsed = time.monotonic() - started
        print(
            f"[run-claude-inst-outer] inner exited code={exit_code} after {elapsed:.1f}s",
            flush=True,
        )

        if elapsed < MIN_RUN_SECONDS:
            print(
                f"[run-claude-inst-outer] fast exit — backing off {backoff:.1f}s",
                flush=True,
            )
            time.sleep(backoff)
            backoff = min(backoff * 2.0, MAX_BACKOFF_SECONDS)
        else:
            backoff = INITIAL_BACKOFF_SECONDS
            time.sleep(RESTART_PAUSE_SECONDS)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except KeyboardInterrupt:
        raise SystemExit(130)
