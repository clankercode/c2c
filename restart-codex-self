#!/usr/bin/env python3
"""
Self-restart helper for a run-codex-inst managed session.

Usage: ./restart-codex-self [instance-name] [--signal SIGNAME]

Reads the pid written by `run-codex-inst` for the given instance
(default: $RUN_CODEX_INST_NAME) and sends it a signal (default: SIGTERM).
When the Codex process exits, `run-codex-inst-outer` relaunches it from the
same config. With a pinned resume id, the new Codex process returns to the
same conversation and receives the config's kickoff prompt.

Codex installations may exec a native `codex` binary or wrapper processes
whose /proc comm is `node`, `npm ...`, or `MainThread`, so those are allowed
by default.
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
DEFAULT_CONFIG_DIR = HERE / "run-codex-inst.d"
FALSE_STRINGS = {"", "0", "false", "no", "off"}


def config_dir() -> Path:
    override = os.environ.get("RUN_CODEX_INST_CONFIG_DIR", "").strip()
    if override:
        return Path(override)
    return DEFAULT_CONFIG_DIR


def pid_path(name: str) -> Path:
    return config_dir() / f"{name}.pid"


def proc_comm(pid: int) -> str | None:
    try:
        return Path(f"/proc/{pid}/comm").read_text(encoding="utf-8").strip()
    except (FileNotFoundError, OSError):
        return None


def dry_run_enabled() -> bool:
    return (
        os.environ.get("RUN_CODEX_RESTART_SELF_DRY_RUN", "").strip().lower()
        not in FALSE_STRINGS
    )


def expected_comm_values(value: str) -> list[str]:
    return [item.strip() for item in value.split(",") if item.strip()]


def comm_matches(comm: str, expected: list[str]) -> bool:
    return any(needle in comm for needle in expected)


def parse_signal(value: str) -> signal.Signals:
    signal_name = value if value.startswith("SIG") else f"SIG{value}"
    try:
        return signal.Signals[signal_name]
    except KeyError:
        raise SystemExit(f"[restart-codex-self] unknown signal: {value}")


def main(argv: list[str]) -> int:
    parser = argparse.ArgumentParser(
        description="Self-restart a run-codex-inst session."
    )
    parser.add_argument(
        "name",
        nargs="?",
        default=os.environ.get("RUN_CODEX_INST_NAME"),
        help="instance name (default: $RUN_CODEX_INST_NAME)",
    )
    parser.add_argument(
        "--signal",
        default="SIGTERM",
        help="signal to send (default: SIGTERM); e.g. SIGINT, SIGHUP, TERM",
    )
    parser.add_argument(
        "--expect-comm",
        default="codex,node,npm,MainThread",
        help=(
            "comma-separated /proc/<pid>/comm substring allowlist "
            "(default: codex,node,npm,MainThread). Use '' to skip the check."
        ),
    )
    args = parser.parse_args(argv[1:])

    if not args.name:
        print(
            "[restart-codex-self] no instance name; pass as arg or set $RUN_CODEX_INST_NAME",
            file=sys.stderr,
        )
        return 2

    pid_file = pid_path(args.name)
    if not pid_file.exists():
        print(f"[restart-codex-self] pid file not found: {pid_file}", file=sys.stderr)
        return 2

    try:
        pid = int(pid_file.read_text(encoding="utf-8").strip())
    except ValueError:
        print(
            f"[restart-codex-self] pid file is not an integer: {pid_file}",
            file=sys.stderr,
        )
        return 2

    if pid <= 1:
        print(f"[restart-codex-self] refusing to signal pid {pid}", file=sys.stderr)
        return 2
    if pid == os.getpid():
        print("[restart-codex-self] refusing to signal our own pid", file=sys.stderr)
        return 2

    comm = proc_comm(pid)
    if comm is None:
        print(
            f"[restart-codex-self] pid {pid} has no /proc entry (already exited?)",
            file=sys.stderr,
        )
        return 3

    expected = expected_comm_values(args.expect_comm)
    if expected and not comm_matches(comm, expected):
        print(
            f"[restart-codex-self] pid {pid} /proc comm is {comm!r}, expected one of {expected!r} - refusing to signal",
            file=sys.stderr,
        )
        return 4

    sig = parse_signal(args.signal)

    if dry_run_enabled():
        print(
            json.dumps(
                {
                    "name": args.name,
                    "pid": pid,
                    "pid_file": str(pid_file),
                    "signal": sig.name,
                    "comm": comm,
                    "dry_run": True,
                },
                indent=2,
            )
        )
        return 0

    print(
        f"[restart-codex-self] sending {sig.name} to pid {pid} (comm={comm!r}) - outer loop will relaunch",
        file=sys.stderr,
        flush=True,
    )
    try:
        os.kill(pid, sig.value)
    except ProcessLookupError:
        print(f"[restart-codex-self] pid {pid} vanished before signal", file=sys.stderr)
        return 3
    except PermissionError:
        print(
            f"[restart-codex-self] permission denied signaling pid {pid}",
            file=sys.stderr,
        )
        return 4
    return 0


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
