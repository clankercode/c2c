# Keep the Docker build context small and deterministic.
.git
.github
.claude
.codex
.goal-loops
.collab
.vscode
.idea
node_modules
_build
_opam
dist
target

# Large/unneeded for the OCaml relay build
tests/
docs/
scripts/
website/
data/

# Python side (the relay container only ships the OCaml binary)
*.py
*.pyc
__pycache__/
.pytest_cache/
.venv/
venv/

# Exception: Python files needed by Dockerfile.agent runtime stage
!c2c_deliver_inbox.py
!c2c_poll_inbox.py
!c2c_poker.py
!c2c_mcp.py
!c2c_registry.py

# Local state
.git/c2c/
*.log
*.sqlite
*.sqlite-journal

# Bind-mount volumes (runtime-created, not needed at build time)
volumes/
