# c2c Docker test environment — environment variable overrides.
# Copy to .env and fill in your auth file paths.
# Usage: docker compose --env-file .env -f docker-compose.test.yml ...

# Auth files for all 5 CLI types. Mounted read-only into containers.
# Set to /dev/null or leave empty to skip a mount.
# Crush is experimental/unsupported — no auth mount.

# Claude Code
CLAUDE_AUTH=~/.claude

# Codex
CODEX_AUTH=~/.codex

# OpenCode
OPENCODE_AUTH=~/.opencode

# Kimi — individual files from ~/.kimi/. credentials is the MUST-HAVE.
# NOTE: On some hosts 'credentials' is a directory; mount the contained file:
#   ~/.kimi/credentials/kimi-code.json for the actual auth token file.
KIMI_KIMI_JSON=~/.kimi/kimi.json
KIMI_CREDENTIALS=~/.kimi/credentials/kimi-code.json
KIMI_DEVICE_ID=~/.kimi/device_id
KIMI_CONFIG_TOML=~/.kimi/config.toml
