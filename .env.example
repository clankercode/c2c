# c2c Docker test environment — environment variable overrides.
# Copy to .env and fill in your auth file paths.
# Usage: docker compose --env-file .env -f docker-compose.test.yml ...

# Individual kimi auth files from ~/.kimi/. All mounted read-only.
# credentials is the MUST-HAVE; other three are nice-to-have.
# Set to /dev/null or leave empty to skip a mount.
# NOTE: On some hosts 'credentials' is a directory; mount the contained file instead.
# e.g. ~/.kimi/credentials/kimi-code.json for the actual auth token file.
KIMI_KIMI_JSON=~/.kimi/kimi.json
KIMI_CREDENTIALS=~/.kimi/credentials/kimi-code.json
KIMI_DEVICE_ID=~/.kimi/device_id
KIMI_CONFIG_TOML=~/.kimi/config.toml
