{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "c2c",
  "version": "0.1.0",
  "identifier": "im.c2c.gui",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "app": {
    "windows": [
      {
        "title": "c2c — Swarm Monitor",
        "width": 1100,
        "height": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'none'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' https://relay.c2c.im; font-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": false,
      "sidecar": false,
      "scope": [
        {
          "name": "c2c",
          "cmd": "c2c",
          "args": true,
          "sidecar": false
        }
      ]
    }
  }
}
