#!/usr/bin/env python3
"""Inner launcher for a named Kimi Code instance.

Usage: ./run-kimi-inst <instance-name> [extra kimi args...]

Reads ./run-kimi-inst.d/<name>.json, builds a Kimi launch command, writes its
own pid to ./run-kimi-inst.d/<name>.pid, sets c2c env vars, and execs Kimi.
os.execvpe preserves the pid, so the companion restart-kimi-self helper can
signal the live Kimi process and let the outer loop relaunch it.

Config keys:
  command         kimi binary path or name (default: "kimi")
  cwd             working directory (default: dir containing this script)
  c2c_session_id  unique MCP session ID for broker registration
  c2c_alias       stable alias peers use to address this instance
                  (defaults to c2c_session_id if absent)
  prompt          if set, runs `kimi --print --prompt "<prompt>"` (non-interactive);
                  omit for interactive TUI mode
  flags           extra CLI flags (list of strings)
  env             extra environment variables (dict string→string)

Set RUN_KIMI_INST_DRY_RUN=1 to print the resolved launch command and env
keys as JSON instead of execing.
"""
from __future__ import annotations

import json
import os
import re
import shlex
import subprocess
import sys
from pathlib import Path

HERE = Path(__file__).resolve().parent
DEFAULT_CONFIG_DIR = HERE / "run-kimi-inst.d"
FALSE_STRINGS = {"0", "false", "no", "off"}
HELP_FLAGS = {"-h", "--help"}


def config_dir() -> Path:
    override = os.environ.get("RUN_KIMI_INST_CONFIG_DIR", "").strip()
    if override:
        return Path(override)
    return DEFAULT_CONFIG_DIR


def config_path(name: str) -> Path:
    return config_dir() / f"{name}.json"


def pid_path(name: str) -> Path:
    return config_dir() / f"{name}.pid"


def load_config(name: str) -> dict:
    path = config_path(name)
    if not path.exists():
        raise SystemExit(f"[run-kimi-inst] config not found: {path}")
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        raise SystemExit(f"[run-kimi-inst] invalid JSON in {path}: {exc}")
    if not isinstance(data, dict):
        raise SystemExit(f"[run-kimi-inst] config root must be an object: {path}")
    return data


def coerce_string_list(value, field: str) -> list[str]:
    if value is None:
        return []
    if not isinstance(value, list) or not all(isinstance(item, str) for item in value):
        raise SystemExit(f"[run-kimi-inst] {field} must be list of strings")
    return list(value)


def coerce_string_dict(value, field: str) -> dict[str, str]:
    if value is None:
        return {}
    if not isinstance(value, dict) or not all(
        isinstance(k, str) and isinstance(v, str) for k, v in value.items()
    ):
        raise SystemExit(f"[run-kimi-inst] {field} must be dict of string to string")
    return dict(value)


def coerce_string(value, field: str, *, required: bool = False) -> str:
    if value is None:
        if required:
            raise SystemExit(f"[run-kimi-inst] {field} is required")
        return ""
    if not isinstance(value, str):
        raise SystemExit(f"[run-kimi-inst] {field} must be a string")
    return value


def default_session_id(name: str) -> str:
    normalized = re.sub(r"[^A-Za-z0-9_.-]+", "-", name.strip()).strip("-")
    return "kimi-" + (normalized or "instance")


def build_launch(
    name: str, config: dict, extra: list[str]
) -> tuple[list[str], Path, dict[str, str], bool]:
    command = coerce_string(config.get("command", "kimi"), "command", required=True)
    flags = coerce_string_list(config.get("flags"), "flags")
    if "--yolo" not in flags and "--yes" not in flags and "-y" not in flags:
        flags.append("--yolo")
    env_extra = coerce_string_dict(config.get("env"), "env")
    cwd = coerce_string(config.get("cwd") or str(HERE), "cwd", required=True)
    cwd_path = Path(cwd).expanduser()
    if not cwd_path.exists():
        raise SystemExit(f"[run-kimi-inst] cwd does not exist: {cwd_path}")

    c2c_session_id = coerce_string(
        config.get("c2c_session_id") or default_session_id(name),
        "c2c_session_id",
        required=True,
    )
    c2c_alias = coerce_string(
        config.get("c2c_alias") or c2c_session_id,
        "c2c_alias",
    )

    prompt = coerce_string(config.get("prompt"), "prompt")
    if prompt:
        # Non-interactive: Kimi takes prompt text via --prompt in print mode.
        launch = [command, *flags, "--print", "--prompt", prompt, *extra]
    else:
        # Interactive TUI mode (no prompt)
        launch = [command, *flags, *extra]

    has_prompt = bool(prompt)
    env = os.environ.copy()
    env.update(env_extra)
    env["RUN_KIMI_INST_NAME"] = name
    env["RUN_KIMI_INST_C2C_SESSION_ID"] = c2c_session_id
    env["C2C_MCP_SESSION_ID"] = c2c_session_id
    env["C2C_MCP_AUTO_REGISTER_ALIAS"] = c2c_alias
    env["C2C_MCP_AUTO_DRAIN_CHANNEL"] = "0"
    return launch, cwd_path, env, has_prompt


def set_terminal_title(title: str) -> None:
    if not sys.stdout.isatty():
        return
    sys.stdout.write(f"\033]0;{title}\007")
    sys.stdout.flush()


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_KIMI_INST_DRY_RUN", "").strip().lower() not in (
        {""} | FALSE_STRINGS
    )


def main(argv: list[str]) -> int:
    if len(argv) == 2 and argv[1] in HELP_FLAGS:
        print(__doc__.strip())
        return 0
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra kimi args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]
    config = load_config(name)
    launch, cwd_path, env, has_prompt = build_launch(name, config, extra)
    title = coerce_string(config.get("title") or name, "title")
    pre_exec = coerce_string_list(config.get("pre_exec"), "pre_exec")
    pid_file = pid_path(name)

    if dry_run_enabled():
        print(
            json.dumps(
                {
                    "launch": launch,
                    "prompt_mode": "non-interactive" if has_prompt else "interactive-tui",
                    "cwd": str(cwd_path),
                    "pid_file": str(pid_file),
                    "env": {
                        "RUN_KIMI_INST_NAME": env["RUN_KIMI_INST_NAME"],
                        "RUN_KIMI_INST_C2C_SESSION_ID": env["RUN_KIMI_INST_C2C_SESSION_ID"],
                        "C2C_MCP_SESSION_ID": env["C2C_MCP_SESSION_ID"],
                        "C2C_MCP_AUTO_REGISTER_ALIAS": env["C2C_MCP_AUTO_REGISTER_ALIAS"],
                    },
                },
                indent=2,
            )
        )
        return 0

    pid_file.parent.mkdir(parents=True, exist_ok=True)
    pid_file.write_text(f"{os.getpid()}\n", encoding="utf-8")

    set_terminal_title(title)
    if pre_exec:
        print(f"[run-kimi-inst] pre_exec: {shlex.join(pre_exec)}", file=sys.stderr)
        subprocess.run(pre_exec, cwd=str(cwd_path), env=env, check=False)

    print(f"[run-kimi-inst] exec {shlex.join(launch)} (cwd={cwd_path})", file=sys.stderr)
    os.chdir(str(cwd_path))
    try:
        os.execvpe(launch[0], launch, env)
    except FileNotFoundError as exc:
        raise SystemExit(f"[run-kimi-inst] command not found: {launch[0]} ({exc})")


if __name__ == "__main__":
    raise SystemExit(main(sys.argv))
