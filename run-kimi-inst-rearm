#!/usr/bin/env python3
"""Rearm background helpers for a managed run-kimi-inst session.

Starts c2c_deliver_inbox.py --notify-only --loop alongside the Kimi process
so messages are delivered near-real-time without manual polling.

Usage: ./run-kimi-inst-rearm <instance-name> [--pid PID] [--session-id ID]
       ./run-kimi-inst-rearm <instance-name> --stop
"""
from __future__ import annotations

import argparse
import json
import os
import signal
import subprocess
import sys
import time
from pathlib import Path
from typing import Any

import c2c_mcp

HERE = Path(__file__).resolve().parent
DEFAULT_CONFIG_DIR = HERE / "run-kimi-inst.d"
FALSE_STRINGS = {"", "0", "false", "no", "off"}


def config_dir() -> Path:
    override = os.environ.get("RUN_KIMI_INST_CONFIG_DIR", "").strip()
    return Path(override) if override else DEFAULT_CONFIG_DIR


def config_path(name: str) -> Path:
    return config_dir() / f"{name}.json"


def pid_path(name: str) -> Path:
    return config_dir() / f"{name}.pid"


def support_pidfile(name: str, kind: str) -> Path:
    return config_dir() / f"{name}.{kind}.pid"


def support_log(name: str, kind: str) -> Path:
    return config_dir() / f"{name}.{kind}.log"


def read_pid(path: Path) -> int | None:
    try:
        return int(path.read_text(encoding="utf-8").strip())
    except (OSError, ValueError):
        return None


def pid_is_alive(pid: int) -> bool:
    if pid <= 0:
        return False
    try:
        os.kill(pid, 0)
    except ProcessLookupError:
        return False
    except PermissionError:
        return True
    return True


def proc_cmdline(pid: int) -> str:
    try:
        raw = Path(f"/proc/{pid}/cmdline").read_bytes()
    except OSError:
        return ""
    return raw.replace(b"\0", b" ").decode("utf-8", errors="replace").strip()


def stop_pidfile(path: Path, expected: str, timeout: float) -> dict[str, Any]:
    pid = read_pid(path)
    result: dict[str, Any] = {"pidfile": str(path), "pid": pid, "stopped": False}
    if pid is None:
        result["reason"] = "missing_or_invalid_pidfile"
        return result
    if not pid_is_alive(pid):
        result["reason"] = "already_dead"
        path.unlink(missing_ok=True)
        return result

    cmdline = proc_cmdline(pid)
    result["cmdline"] = cmdline
    if expected not in cmdline:
        result["reason"] = "unexpected_process"
        return result

    os.kill(pid, signal.SIGTERM)
    deadline = time.monotonic() + timeout
    while time.monotonic() < deadline:
        if not pid_is_alive(pid):
            path.unlink(missing_ok=True)
            result["stopped"] = True
            result["reason"] = "terminated"
            return result
        time.sleep(0.05)

    os.kill(pid, signal.SIGKILL)
    path.unlink(missing_ok=True)
    result["stopped"] = True
    result["reason"] = "killed"
    return result


def load_config(name: str) -> dict[str, Any]:
    path = config_path(name)
    try:
        return json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return {}


def broker_root() -> Path:
    override = os.environ.get("C2C_MCP_BROKER_ROOT", "").strip()
    return Path(override) if override else c2c_mcp.default_broker_root()


def default_session_id(name: str) -> str:
    env_value = os.environ.get("RUN_KIMI_INST_C2C_SESSION_ID", "").strip()
    if env_value:
        return env_value
    config_value = str(load_config(name).get("c2c_session_id", "")).strip()
    if config_value:
        return config_value
    return f"kimi-{name}"


def default_alias(name: str, session_id: str) -> str:
    env_value = os.environ.get("RUN_KIMI_INST_C2C_ALIAS", "").strip()
    if env_value:
        return env_value
    config_value = str(load_config(name).get("c2c_alias", "")).strip()
    if config_value:
        return config_value
    return session_id or f"kimi-{name}"


def live_broker_pid(session_id: str, alias: str) -> int | None:
    registry_path = broker_root() / "registry.json"
    for registration in c2c_mcp.load_broker_registrations(registry_path):
        if (
            registration.get("session_id") != session_id
            and registration.get("alias") != alias
        ):
            continue
        if not c2c_mcp.broker_registration_is_alive(registration):
            continue
        pid = registration.get("pid")
        if isinstance(pid, int) and not isinstance(pid, bool):
            return pid
    return None


def resolve_target_pid(
    name: str, explicit_pid: int | None, session_id: str, alias: str
) -> dict[str, Any]:
    pidfile_pid = read_pid(pid_path(name))
    if explicit_pid is not None:
        if pid_is_alive(explicit_pid):
            return {
                "ok": True,
                "target_pid": explicit_pid,
                "target_source": "argument",
                "pidfile_pid": pidfile_pid,
            }
        return {
            "ok": False,
            "reason": "explicit_pid_not_alive",
            "target_pid": explicit_pid,
            "target_source": "argument",
            "pidfile_pid": pidfile_pid,
        }

    if pidfile_pid is not None and pid_is_alive(pidfile_pid):
        return {
            "ok": True,
            "target_pid": pidfile_pid,
            "target_source": "pidfile",
            "pidfile_pid": pidfile_pid,
        }

    broker_pid = live_broker_pid(session_id, alias)
    if broker_pid is not None:
        return {
            "ok": True,
            "target_pid": broker_pid,
            "target_source": "broker",
            "pidfile_pid": pidfile_pid,
        }

    reason = "pidfile_pid_not_alive" if pidfile_pid is not None else "pidfile_missing"
    return {
        "ok": False,
        "reason": reason,
        "target_pid": pidfile_pid,
        "target_source": "pidfile",
        "pidfile_pid": pidfile_pid,
    }


def build_deliver_command(
    name: str, target_pid: int, session_id: str, start_timeout: float
) -> list[str]:
    deliver_pidfile = support_pidfile(name, "deliver")
    return [
        sys.executable,
        str(HERE / "c2c_deliver_inbox.py"),
        "--client",
        "kimi",
        "--pid",
        str(target_pid),
        "--session-id",
        session_id,
        "--file-fallback",
        "--notify-only",
        "--notify-debounce",
        "30",
        "--loop",
        "--interval",
        "2",
        "--pidfile",
        str(deliver_pidfile),
        "--daemon",
        "--daemon-log",
        str(support_log(name, "deliver")),
        "--daemon-timeout",
        f"{start_timeout:g}",
        "--json",
    ]


def dry_run_enabled(args: argparse.Namespace) -> bool:
    if args.dry_run:
        return True
    return (
        os.environ.get("RUN_KIMI_INST_REARM_DRY_RUN", "").strip().lower()
        not in FALSE_STRINGS
    )


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Restart Kimi support loops for a run-kimi-inst instance."
    )
    parser.add_argument("name")
    parser.add_argument("--pid", type=int, default=None)
    parser.add_argument("--session-id", default="")
    parser.add_argument("--stop", action="store_true", help="stop deliver daemon and exit")
    parser.add_argument("--dry-run", action="store_true")
    parser.add_argument("--json", action="store_true")
    parser.add_argument("--stop-timeout", type=float, default=2.0)
    parser.add_argument("--start-timeout", type=float, default=30.0)
    args = parser.parse_args(sys.argv[1:] if argv is None else argv)

    if args.stop:
        stopped = [
            stop_pidfile(
                support_pidfile(args.name, "deliver"),
                "c2c_deliver_inbox.py",
                args.stop_timeout,
            ),
        ]
        if args.json:
            print(json.dumps({"stopped": stopped}, indent=2))
        else:
            print(f"stopped deliver daemon for {args.name}")
        return 0

    session_id = args.session_id or default_session_id(args.name)
    alias = default_alias(args.name, session_id)
    resolved = resolve_target_pid(args.name, args.pid, session_id, alias)
    if not resolved["ok"]:
        print(
            "[run-kimi-inst-rearm] no live target pid found "
            f"for {args.name}: {resolved['reason']} "
            f"(pidfile={pid_path(args.name)})",
            file=sys.stderr,
        )
        if args.json:
            print(
                json.dumps(
                    {
                        "ok": False,
                        "name": args.name,
                        "session_id": session_id,
                        "alias": alias,
                        **resolved,
                    },
                    indent=2,
                )
            )
        return 2

    target_pid = int(resolved["target_pid"])
    deliver_command = build_deliver_command(args.name, target_pid, session_id, args.start_timeout)

    payload: dict[str, Any] = {
        "ok": True,
        "name": args.name,
        "target_pid": target_pid,
        "target_source": resolved["target_source"],
        "pidfile_pid": resolved["pidfile_pid"],
        "session_id": session_id,
        "alias": alias,
        "pidfiles": {"deliver": str(support_pidfile(args.name, "deliver"))},
        "commands": [deliver_command],
        "dry_run": dry_run_enabled(args),
    }

    if payload["dry_run"]:
        if args.json:
            print(json.dumps(payload, indent=2))
        else:
            print(f"would rearm Kimi deliver daemon for {args.name} pid={target_pid}")
        return 0

    stopped = [
        stop_pidfile(
            support_pidfile(args.name, "deliver"),
            "c2c_deliver_inbox.py",
            args.stop_timeout,
        ),
    ]
    deliver = subprocess.run(
        deliver_command,
        cwd=HERE,
        check=False,
        capture_output=True,
        text=True,
    )
    payload["stopped"] = stopped
    payload["started"] = {
        "deliver": {
            "ok": deliver.returncode == 0,
            "returncode": deliver.returncode,
            "stdout": deliver.stdout.strip(),
            "stderr": deliver.stderr.strip(),
        },
    }
    payload["ok"] = deliver.returncode == 0
    if args.json:
        print(json.dumps(payload, indent=2))
    else:
        state = "rearmed" if payload["ok"] else "failed to rearm"
        print(f"{state} Kimi deliver daemon for {args.name}")
    return 0 if payload["ok"] else 1


if __name__ == "__main__":
    raise SystemExit(main())
