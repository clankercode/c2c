#!/usr/bin/env python3
"""
Outer restart loop for run-codex-inst.

Usage: ./run-codex-inst-outer <instance-name> [extra codex args...]
"""
from __future__ import annotations

import json
import subprocess
import sys

print(f"DEPRECATED: {__file__} is deprecated — use 'c2c start codex' instead. See CLAUDE.md.", file=__import__('sys').stderr)

import time
from pathlib import Path
import os

MIN_RUN_SECONDS = 10.0
RESTART_PAUSE_SECONDS = 1.5
INITIAL_BACKOFF_SECONDS = 2.0
MAX_BACKOFF_SECONDS = 60.0
DOUBLE_SIGINT_WINDOW_SECONDS = 2.0

HERE = Path(__file__).resolve().parent
INNER = HERE / "run-codex-inst"


def dry_run_enabled() -> bool:
    return os.environ.get("RUN_CODEX_INST_OUTER_DRY_RUN", "").strip().lower() not in {
        "",
        "0",
        "false",
        "no",
        "off",
    }


def inner_command(name: str, extra: list[str]) -> list[str]:
    return [sys.executable, str(INNER), name, *extra]


def _load_instance_config(name: str) -> dict:
    cfg_path = HERE / "run-codex-inst.d" / f"{name}.json"
    if not cfg_path.exists():
        return {}
    try:
        return json.loads(cfg_path.read_text(encoding="utf-8"))
    except (json.JSONDecodeError, OSError):
        return {}


def _load_instance_alias(name: str) -> str | None:
    cfg = _load_instance_config(name)
    return cfg.get("c2c_alias") or cfg.get("c2c_session_id") or None


def _load_instance_session_id(name: str) -> str | None:
    cfg = _load_instance_config(name)
    return cfg.get("c2c_session_id") or cfg.get("env", {}).get("C2C_MCP_SESSION_ID") or None


def maybe_refresh_peer(name: str, pid: int) -> None:
    """Update the broker registry to point <name>'s alias at the new child PID."""
    alias = _load_instance_alias(name)
    if not alias:
        return
    refresh = HERE / "c2c_refresh_peer.py"
    if not refresh.exists():
        return
    cmd = [sys.executable, str(refresh), alias, "--pid", str(pid)]
    session_id = _load_instance_session_id(name)
    if session_id:
        cmd += ["--session-id", session_id]
    try:
        result = subprocess.run(
            cmd,
            cwd=HERE,
            capture_output=True,
            text=True,
            timeout=5.0,
        )
        if result.returncode != 0:
            stderr = result.stderr.strip()
            if "No registration found" not in stderr:
                print(
                    f"[run-codex-inst-outer] refresh-peer warning: {stderr}",
                    file=sys.stderr,
                    flush=True,
                )
    except Exception as exc:
        print(
            f"[run-codex-inst-outer] refresh-peer error: {exc}",
            file=sys.stderr,
            flush=True,
        )


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(f"usage: {argv[0]} <instance-name> [extra codex args...]", file=sys.stderr)
        return 2

    name = argv[1]
    extra = argv[2:]

    if not INNER.exists():
        print(f"inner script not found: {INNER}", file=sys.stderr)
        return 2

    command = inner_command(name, extra)
    if dry_run_enabled():
        print(json.dumps({"inner": command}, indent=2))
        return 0

    backoff = INITIAL_BACKOFF_SECONDS
    last_sigint = 0.0
    iteration = 0

    while True:
        iteration += 1
        try:
            import c2c_mcp as _c2c_mcp
            _n = _c2c_mcp.cleanup_stale_tmp_fea_so()
            if _n:
                print(f"[run-codex-inst-outer] cleaned {_n} stale /tmp/.fea*.so file(s)", flush=True)
        except Exception:
            pass
        print(f"[run-codex-inst-outer] iter {iteration}: launching {name}", flush=True)
        started = time.monotonic()
        proc = None
        try:
            proc = subprocess.Popen(command, cwd=HERE)
            maybe_refresh_peer(name, proc.pid)
            exit_code = proc.wait()
        except KeyboardInterrupt:
            now = time.monotonic()
            if proc is not None and proc.poll() is None:
                proc.terminate()
                try:
                    proc.wait(timeout=2.0)
                except subprocess.TimeoutExpired:
                    proc.kill()
                    proc.wait()
            if now - last_sigint < DOUBLE_SIGINT_WINDOW_SECONDS:
                print("[run-codex-inst-outer] double SIGINT - exiting.", flush=True)
                return 130
            last_sigint = now
            print(
                "[run-codex-inst-outer] SIGINT received. Send again within "
                f"{DOUBLE_SIGINT_WINDOW_SECONDS:.1f}s to exit the loop.",
                flush=True,
            )
            exit_code = 130
        except FileNotFoundError as exc:
            print(f"[run-codex-inst-outer] failed to launch: {exc}", file=sys.stderr)
            return 2

        elapsed = time.monotonic() - started
        print(
            f"[run-codex-inst-outer] inner exited code={exit_code} after {elapsed:.1f}s",
            flush=True,
        )

        if elapsed < MIN_RUN_SECONDS:
            print(
                f"[run-codex-inst-outer] fast exit - backing off {backoff:.1f}s",
                flush=True,
            )
            time.sleep(backoff)
            backoff = min(backoff * 2.0, MAX_BACKOFF_SECONDS)
        else:
            backoff = INITIAL_BACKOFF_SECONDS
            time.sleep(RESTART_PAUSE_SECONDS)


if __name__ == "__main__":
    try:
        raise SystemExit(main(sys.argv))
    except KeyboardInterrupt:
        raise SystemExit(130)
